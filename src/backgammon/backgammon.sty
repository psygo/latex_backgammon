\usepackage{tikz}
\usetikzlibrary{shapes.geometric}

% Whether the point numbers 1-24 are drawn around the board; see the
% `coordinates` key on the `backgammon` environment.
\newif\ifbackgammonShowCoordinates

% Whether the left/right side columns (for the doubling die and the
% checkers that have left the board, respectively) take up any space at
% all; see the `left column`/`right column` keys on the `backgammon`
% environment.
\newif\ifbackgammonShowLeftColumn
\newif\ifbackgammonShowRightColumn

% The two alternating colors of the triangles ("files").
\definecolor{backgammonLight}{HTML}{F0D9B5}
\definecolor{backgammonDark}{HTML}{8B5A2B}

% Which way a file's triangle points: "up", for the files on the bottom
% half of the board, or "down", for the files on the top half. Each
% choice sets both the shape's own rotation and which of its anchors
% ends up on the flat base, so that the base (not the apex) is always
% the point placed at the pic's `at (...)` coordinate.
%
% This is deliberately implemented via plain macros (\bgFileRotate,
% \bgFileAnchor) rather than passing `shape border rotate`/`anchor`
% straight through as pic options: those keys would need to be repeated
% literally inside the triangle's own \node[...] below, and a key given
% directly on a node always wins over the same key set by an enclosing
% pic/scope, silently ignoring whatever the caller passed in.
\tikzset{
  backgammon file direction/.is choice,
  backgammon file direction/up/.code   = {\def\bgFileRotate{90}\def\bgFileAnchor{south}},
  backgammon file direction/down/.code = {\def\bgFileRotate{270}\def\bgFileAnchor{north}},
  backgammon file direction/.default   = up,
  backgammon file direction            = up,
}

% Generic `/tikz/pics` options (rather than ones scoped under any
% particular pic) so they can be passed in the same key-list as a
% pic's own argument, e.g. `\pic {backgammon doubling die = 64, scale =
% 1.5, font size = 12pt}`. Only `backgammon doubling die` reads
% `\bgPicScale`/`\bgPicFontSize` today, so this has no effect on other
% pics; they default back for any invocation that doesn't set them
% explicitly, the same way `backgammon file direction` does above.
\tikzset{
  /tikz/pics/scale/.store in = \bgPicScale,
  /tikz/pics/scale/.default  = 1,
  /tikz/pics/scale           = 1,
  /tikz/pics/font size/.store in = \bgPicFontSize,
  /tikz/pics/font size/.default  = 10pt,
  /tikz/pics/font size           = 10pt,
}

% The board's layout constants, for the 5 regions from left to right:
%   [left col][quadrant A: 6 files][bar][quadrant B: 6 files][right col]
%
% This is a plain macro (rather than a pic of its own) so that both
% `backgammon board` and `backgammon coordinates` can compute the same
% positions without one having to reach into the other's local scope.
%
% Throughout this file, a plain number denotes TikZ's default
% coordinate unit, i.e. 1cm (so e.g. `\bgHeight = 4` means 4cm before
% any further scaling). The left/right columns (when shown) are given
% directly in physical cm by the user (`side column width`) and are
% NOT stretched by `board width`: instead, `\bgPointWidth` -- and so
% the whole point grid (12 points + the bar) -- is computed to exactly
% fill whatever width `board width` leaves over, so the side columns
% always come out exactly the size the user asked for, regardless of
% how wide the board itself is. They collapse to width 0 when disabled
% (see `left column`/`right column`), so the point grid simply expands
% to fill the space they would have taken.
\def\bgSetupBoardLayout{%
  \def\bgPointsPerQuadrant{6}%
  \def\bgBarWidthInPoints{1}%
  \def\bgHeight{4}%
  \ifbackgammonShowLeftColumn
    \pgfmathsetmacro\bgLeftColWidth{\backgammonSideColWidth / 1cm}%
  \else
    \def\bgLeftColWidth{0}%
  \fi
  \ifbackgammonShowRightColumn
    \pgfmathsetmacro\bgRightColWidth{\backgammonSideColWidth / 1cm}%
  \else
    \def\bgRightColWidth{0}%
  \fi
  \pgfmathsetmacro\bgTargetBoardWidth{\backgammonBoardWidth / 1cm}%
  \pgfmathsetmacro\bgPointWidth{%
    (\bgTargetBoardWidth - \bgLeftColWidth - \bgRightColWidth)
    / (2*\bgPointsPerQuadrant + \bgBarWidthInPoints)%
  }%
  \pgfmathsetmacro\bgBarWidth{\bgBarWidthInPoints * \bgPointWidth}%
  \pgfmathsetmacro\bgQuadrantWidth{\bgPointWidth * \bgPointsPerQuadrant}%
  \pgfmathsetmacro\bgQuadrantAX{\bgLeftColWidth}%
  \pgfmathsetmacro\bgBarX{\bgQuadrantAX + \bgQuadrantWidth}%
  \pgfmathsetmacro\bgQuadrantBX{\bgBarX + \bgBarWidth}%
  \pgfmathsetmacro\bgRightColX{\bgQuadrantBX + \bgQuadrantWidth}%
  \pgfmathsetmacro\bgBoardWidth{\bgRightColX + \bgRightColWidth}%
}

% Translates a (point number, stack index) pair -- point numbers 1-24,
% following the exact same convention as `backgammon coordinates`'s
% point labels -- into an actual `(x, y)` coordinate on the board, so
% pieces can be placed like `\pic at (point cs:1,1) {backgammon
% checker = light};` instead of by hand with
% `\bgQuadrantAX`/`\bgPointWidth`/etc. The stack index is 1-based,
% counting outward from the board's edge (i.e. away from the center),
% spaced one `checker size` apart.
%
% This is a proper TikZ coordinate system (`\tikzdeclarecoordinatesystem`)
% rather than a macro expanding to `(x, y)` text: TikZ's `at <coord>`
% parser decides whether what follows is a coordinate by peeking at the
% very next token *without* expanding it, so a macro call (which isn't
% literally a `(`) fails to parse. Writing the real `(` ourselves and
% deferring only the `point cs:...` part to our own code sidesteps that
% entirely, and lets us run arbitrary TeX (the `\ifnum` chain below)
% while computing the point, which a plain expandable macro couldn't.
\def\bgPointCoordinateSystem#1,#2\bgPointCoordinateSystemEnd{%
  \bgSetupBoardLayout
  \pgfmathtruncatemacro\bgPointNum{#1}%
  \pgfmathsetmacro\bgStackSpacing{(\backgammonCheckerSize / 1cm) / \bgYScale}%
  \pgfmathsetmacro\bgStackY{(#2 - 0.5) * \bgStackSpacing}%
  \ifnum\bgPointNum<7
    \pgfmathsetmacro\bgPointX{\bgQuadrantBX + (6.5  - \bgPointNum) * \bgPointWidth}%
    \pgfmathsetmacro\bgPointY{\bgStackY}%
  \else\ifnum\bgPointNum<13
    \pgfmathsetmacro\bgPointX{\bgQuadrantAX + (12.5 - \bgPointNum) * \bgPointWidth}%
    \pgfmathsetmacro\bgPointY{\bgStackY}%
  \else\ifnum\bgPointNum<19
    \pgfmathsetmacro\bgPointX{\bgQuadrantAX + (\bgPointNum - 12.5) * \bgPointWidth}%
    \pgfmathsetmacro\bgPointY{\bgHeight - \bgStackY}%
  \else
    \pgfmathsetmacro\bgPointX{\bgQuadrantBX + (\bgPointNum - 18.5) * \bgPointWidth}%
    \pgfmathsetmacro\bgPointY{\bgHeight - \bgStackY}%
  \fi\fi\fi
  \pgfpointxy{\bgPointX}{\bgPointY}%
}
\tikzdeclarecoordinatesystem{point}{\bgPointCoordinateSystem#1\bgPointCoordinateSystemEnd}

\pgfkeys{
  % These are the background triangles used for each file.
  %
  % The shape's own local origin is anchored to its base (the flat edge),
  % with the apex pointing towards +x by default. See `backgammon file
  % direction` above for how the up/down orientation is controlled.
  %
  % The fill color is deliberately left unset here so that it can be
  % passed in when the pic is placed, e.g. `\pic[fill = backgammonDark]`.
  %
  % The width is derived from `file gap` (an absolute physical gap
  % left between two neighboring files, subtracted from the point
  % width computed in `\bgSetupBoardLayout`) rather than being a size
  % of its own, so that the triangles always stay centered on, and
  % touching, their point on the grid.
  /tikz/pics/backgammon file bg triangle/.style={
    code={
      \bgSetupBoardLayout
      \pgfmathsetmacro\bgFileGapUnits{\backgammonFileGap / 1cm}
      \pgfmathsetmacro\bgFileWidth{\bgPointWidth - \bgFileGapUnits}
      \node[%
        isosceles triangle,
        isosceles triangle stretches,
        isosceles triangle apex angle = 30,
        shape border rotate            = \bgFileRotate,
        minimum height                 = \backgammonFileHeight,
        minimum width                  = \bgFileWidth cm,
        inner sep                      = 0pt,
        anchor                         = \bgFileAnchor,
        fill, % the color itself is set when the pic is placed
        transform shape = false, % stay a true triangle; see `backgammon`
      ]
        (triangle) at (0, 0){};
      }
  },
  % The point numbers 1-24, following the usual convention: 1-6 along the
  % bottom right (nearest the right column), continuing counterclockwise
  % through 7-12 (bottom left), 13-18 (top left) and 19-24 (top right).
  /tikz/pics/backgammon coordinates/.style={
    code={
      \bgSetupBoardLayout
      % `coordinates gap` is an absolute physical distance, but this
      % pic's y-coordinates are on the same pre-`yscale` grid as
      % `\bgHeight` (see `backgammon`'s environment code), so it has to
      % be converted back into that grid's units by dividing out
      % `\bgYScale` here -- otherwise the gap itself would grow or
      % shrink along with `board height` instead of staying fixed.
      \pgfmathsetmacro\bgCoordGap{(\backgammonCoordinatesGap / 1cm) / \bgYScale}
      \foreach \i in {0, ..., 5} {
        \pgfmathsetmacro\bgLabelAX{\bgQuadrantAX + (\i + 0.5)*\bgPointWidth}
        \pgfmathsetmacro\bgLabelBX{\bgQuadrantBX + (\i + 0.5)*\bgPointWidth}

        \pgfmathtruncatemacro\bgLabelBottomA{2*\bgPointsPerQuadrant - \i}
        \pgfmathtruncatemacro\bgLabelBottomB{\bgPointsPerQuadrant - \i}
        \pgfmathtruncatemacro\bgLabelTopA{2*\bgPointsPerQuadrant + 1 + \i}
        \pgfmathtruncatemacro\bgLabelTopB{3*\bgPointsPerQuadrant + 1 + \i}

        \node[font=\fontsize{\backgammonCoordinatesFontSize}{\backgammonCoordinatesFontSize}\selectfont\bfseries, transform shape = false] at (\bgLabelAX, -\bgCoordGap)             {\bgLabelBottomA};
        \node[font=\fontsize{\backgammonCoordinatesFontSize}{\backgammonCoordinatesFontSize}\selectfont\bfseries, transform shape = false] at (\bgLabelBX, -\bgCoordGap)             {\bgLabelBottomB};
        \node[font=\fontsize{\backgammonCoordinatesFontSize}{\backgammonCoordinatesFontSize}\selectfont\bfseries, transform shape = false] at (\bgLabelAX, \bgHeight + \bgCoordGap)  {\bgLabelTopA};
        \node[font=\fontsize{\backgammonCoordinatesFontSize}{\backgammonCoordinatesFontSize}\selectfont\bfseries, transform shape = false] at (\bgLabelBX, \bgHeight + \bgCoordGap)  {\bgLabelTopB};
      }
    }
  },
  % The backgammon board consists of, from left to right:
  %
  %   1. A column on the left, with the doubling die in the middle.
  %   2. A rectangle with files for the pieces.
  %   3. A column in the center, for the captured checkers.
  %   4. Another rectangle with files for the pieces.
  %   5. A column on the right, for the pieces which leave the board.
  /tikz/pics/backgammon board/.style={
    code={
      \bgSetupBoardLayout

      % 1. The outer outline, plus the dividers between the regions. The
      %    left/right dividers are only drawn when that column is
      %    actually shown, since otherwise they'd just double up on the
      %    outer outline (their width having collapsed to 0).
      \draw (0, 0) rectangle (\bgBoardWidth, \bgHeight);
      \ifbackgammonShowLeftColumn
        \draw (\bgQuadrantAX, 0) -- (\bgQuadrantAX, \bgHeight);
      \fi
      \draw (\bgBarX,       0) -- (\bgBarX,       \bgHeight);
      \draw (\bgQuadrantBX, 0) -- (\bgQuadrantBX, \bgHeight);
      \ifbackgammonShowRightColumn
        \draw (\bgRightColX, 0) -- (\bgRightColX, \bgHeight);
      \fi

      % 2. The 2 x 6 files in each of the 2 rectangles (24 in total),
      %    alternating colors continuously across both quadrants.
      \foreach \n in {0, ..., 11} {
        \ifnum\n<6
          \pgfmathsetmacro\bgFileX{\bgQuadrantAX + (\n + 0.5)*\bgPointWidth}
        \else
          \pgfmathsetmacro\bgFileX{\bgQuadrantBX + (\n - 6 + 0.5)*\bgPointWidth}
        \fi
        \ifodd\n
          \pic[fill = \backgammonFileColorDark]  at (\bgFileX, 0)        {backgammon file bg triangle};
          \pic[fill = \backgammonFileColorLight, backgammon file direction = down] at (\bgFileX, \bgHeight) {backgammon file bg triangle};
        \else
          \pic[fill = \backgammonFileColorLight] at (\bgFileX, 0)        {backgammon file bg triangle};
          \pic[fill = \backgammonFileColorDark,  backgammon file direction = down] at (\bgFileX, \bgHeight) {backgammon file bg triangle};
        \fi
      }

      % 3. The bar, in the center, for the captured checkers:
      % TODO

      % 4. The column on the left, for the doubling die: this is left
      %    empty here. The die's value and position are up to the user,
      %    placed like any other piece via a `\pic` inside `backgammon`,
      %    e.g. `\pic at (\bgLeftColWidth/2, \bgHeight/2)
      %    {backgammon doubling die = 64};`.

      % 5. The column on the right, for the checkers that have left the board:
      % TODO

      % 6. Use the backgammon coordinates (optional, see the
      %    `coordinates` key on the `backgammon` environment)
      \ifbackgammonShowCoordinates
        \pic {backgammon coordinates};
      \fi
    }
  },
  % A single checker, its side ("light" or "dark", matching the same
  % naming as `light file color`/`dark file color`) passed as the
  % pic's argument, e.g. `\pic at (x, y) {backgammon checker = light}`.
  % Like `backgammon doubling die`, it's placed by the user (not the
  % board); its color comes from `light checker color`/`dark checker
  % color`, its outline from `checker border width`, and its diameter
  % is `checker size` multiplied by the shared `scale` pic option
  % (e.g. `\pic at (x, y) {backgammon checker = light, scale = 0.9}`).
  /tikz/pics/backgammon checker/.is choice,
  /tikz/pics/backgammon checker/light/.style = {
    code = {
      \pgfmathsetmacro\bgCheckerDiameter{(\backgammonCheckerSize / 1cm) * \bgPicScale}
      \node[
        draw,
        line width     = \backgammonCheckerBorderWidth,
        circle,
        fill           = \backgammonCheckerColorLight,
        minimum width  = \bgCheckerDiameter cm,
        minimum height = \bgCheckerDiameter cm,
        inner sep      = 0pt,
        transform shape = false, % stay a true circle; see `backgammon`
      ] at (0, 0) {};
    }
  },
  /tikz/pics/backgammon checker/dark/.style = {
    code = {
      \pgfmathsetmacro\bgCheckerDiameter{(\backgammonCheckerSize / 1cm) * \bgPicScale}
      \node[
        draw,
        line width     = \backgammonCheckerBorderWidth,
        circle,
        fill           = \backgammonCheckerColorDark,
        minimum width  = \bgCheckerDiameter cm,
        minimum height = \bgCheckerDiameter cm,
        inner sep      = 0pt,
        transform shape = false, % stay a true circle; see `backgammon`
      ] at (0, 0) {};
    }
  },
  /tikz/pics/backgammon die/.style={
    code={

    }
  },
  % The doubling die (cube), showing the current stake value (2, 4, 8,
  % 16, 32 or 64) passed as the pic's argument, e.g.
  % `\pic {backgammon doubling die = 64}`. Its overall size is the base
  % 0.9cm die multiplied by `scale`, and its digits are set in `font
  % size` (base 10pt), also multiplied by `scale` so a scaled-up die
  % keeps looking proportioned even without adjusting `font size` too.
  % Both are pic options of their own -- passed alongside the value in
  % the same braces, e.g. `\pic {backgammon doubling die = 64, scale =
  % 1.5, font size = 12pt}`. They're deliberately custom `/tikz/pics`
  % options (see their `\tikzset` above) rather than relying on
  % genuine TikZ canvas scaling: the die's node sets `transform shape =
  % false` (to stay undistorted under `backgammon`'s own `yscale`),
  % which would just as well cancel out a real canvas scale wrapped
  % around this pic.
  /tikz/pics/backgammon doubling die/.style args={#1}{
    code={
      \pgfmathsetmacro\bgDoublingDieSize{0.9 * \bgPicScale}
      \pgfmathsetlengthmacro\bgDoublingDieFontSize{\bgPicFontSize * \bgPicScale}
      \node[
        draw,
        fill            = white,
        text            = black,
        font            = \fontsize{\bgDoublingDieFontSize}{\bgDoublingDieFontSize}\selectfont\bfseries,
        rounded corners = 1mm,
        minimum width   = \bgDoublingDieSize cm,
        minimum height  = \bgDoublingDieSize cm,
        inner sep       = 0pt,
        transform shape = false, % stay a true square; see `backgammon`
      ] at (0, 0) {#1};
    }
  },
  /phili/backgammon/.cd,
    % The board's physical size. These are independent (rather than a
    % single `board dimension` that scales both together), so the board
    % can be stretched to a non-natural aspect ratio if desired.
    board width/.store in  = \backgammonBoardWidth,
    board width            = 18cm,
    board height/.store in = \backgammonBoardHeight,
    board height           = 4cm,
    coordinates/.is if        = backgammonShowCoordinates,
    coordinates/.default      = true,
    coordinates               = true,
    % The distance between the board's outer edge and the point-number
    % labels, and their font size. Both are absolute physical sizes,
    % just like `board width`/`board height`, unaffected by the
    % board's own scaling.
    coordinates gap/.store in       = \backgammonCoordinatesGap,
    coordinates gap                 = 0.3cm,
    coordinates font size/.store in = \backgammonCoordinatesFontSize,
    coordinates font size           = 9pt,
    % The two alternating colors of the file triangles.
    light file color/.store in = \backgammonFileColorLight,
    light file color           = backgammonLight,
    dark file color/.store in  = \backgammonFileColorDark,
    dark file color            = backgammonDark,
    % The two checker colors (see `backgammon checker`'s `light`/`dark`
    % argument), their outline width, and their diameter (an absolute
    % physical size, like `board width`, multiplied by that pic's own
    % `scale` option).
    light checker color/.store in = \backgammonCheckerColorLight,
    light checker color           = white,
    dark checker color/.store in  = \backgammonCheckerColorDark,
    dark checker color            = black,
    checker border width/.store in = \backgammonCheckerBorderWidth,
    checker border width            = 1pt,
    checker size/.store in = \backgammonCheckerSize,
    checker size           = 0.9cm,
    % How tall the file triangles are, and how much physical space is
    % left as a gap between neighboring files (see `backgammon file bg
    % triangle` above). Both are absolute physical sizes, rather than
    % being relative to the point spacing.
    file height/.store in = \backgammonFileHeight,
    file height           = 1.7cm,
    file gap/.store in    = \backgammonFileGap,
    file gap              = 0.1cm,
    % Whether the left/right side columns take up any space at all.
    left column/.is if    = backgammonShowLeftColumn,
    left column/.default  = true,
    left column           = true,
    right column/.is if   = backgammonShowRightColumn,
    right column/.default = true,
    right column          = true,
    % The width of the left/right side columns, when shown. This is an
    % absolute physical size: see `\bgSetupBoardLayout` for how the
    % point grid is sized to fill whatever `board width` leaves over
    % after these, rather than the side columns being stretched along
    % with everything else.
    side column width/.store in = \backgammonSideColWidth,
    side column width           = 1.5cm,
}

\newenvironment{backgammon}[1][]{%
  \begin{tikzpicture}
    % `#1` is deliberately applied via `\pgfqkeys` (which takes the
    % path as a separate argument) rather than `\tikzset{/phili/
    % backgammon/.cd, #1}`: `\newenvironment`'s optional argument keeps
    % any leading whitespace it was given (e.g. from a line break right
    % after the opening `[`), and pgfkeys fails to match a key whose
    % name has that whitespace glued to the front of it -- but only
    % when the `.cd` and the (whitespace-prefixed) key list are given
    % to the same `\pgfkeys`/`\tikzset` call, as they would be here.
    \pgfqkeys{/phili/backgammon}{#1}
    % The horizontal axis needs no extra scaling here: `\bgSetupBoardLayout`
    % already sizes the point grid to exactly fill `board width` (minus
    % the side columns, which are their own absolute physical size --
    % see the comment there). The vertical axis is a single region
    % (there's no analogous "some things are absolute" split for
    % height), so it keeps the simpler approach of drawing on a
    % fixed-height grid and stretching it to `board height` via `yscale`.
    %
    % `transform shape` IS needed here, even though only `yscale` is
    % non-1 and we don't want that stretch to distort node shapes: a
    % `\pic` (unlike a plain `\node`) only positions itself according to
    % the ambient scale/rotate if `transform shape` is in effect for it
    % -- without it, every `\pic` in here (the board itself, each file,
    % the coordinate labels, any piece the user places) would render at
    % its natural, un-stretched y position, ignoring `board height`
    % entirely instead of just being placed wrong.
    %
    % So `transform shape` is enabled here for correct positioning, and
    % every leaf shape that shouldn't be distorted by it (the file
    % triangles, the doubling die, the coordinate labels) explicitly
    % sets `transform shape = false` on its own node to opt back out --
    % which only cancels the shape's own rendering, not its position.
    %
    % This scope is left open here and only closed in the environment's
    % end code, so that any pieces (checkers, dice, ...) the user places
    % with their own `\pic` commands inside `backgammon` share the same
    % grid coordinates and the same scaling as the board itself.
    \bgSetupBoardLayout
    \pgfmathsetmacro\bgYScale{\backgammonBoardHeight / (\bgHeight cm)}
    \begin{scope}[yscale = \bgYScale, transform shape]
      \pic{backgammon board};
}{
    \end{scope}
  \end{tikzpicture}%
}